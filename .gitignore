# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code session/agent artifacts (worktrees, local settings, hooks).
# Anything inside .claude/ is per-session state and must not be committed,
# EXCEPT .claude/methodology/ which is versioned playbook documentation.
.claude/*
!.claude/methodology/
!.claude/methodology/**

# Lint baseline snapshot — regenerated locally with `npm run lint > LINT_BASELINE.txt`.
# Tracking it in git would generate noisy diffs on every lint-config change.
LINT_BASELINE.txt

# Husky internal runtime — regenerated by the `prepare` script on npm install.
# Only the user-defined hooks (pre-commit, pre-push, ...) are committed.
.husky/_
